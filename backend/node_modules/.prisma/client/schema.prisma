generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  role         String   @default("editor")
  createdAt    DateTime @default(now()) @map("created_at")

  profile    Profile?
  mediaFiles MediaFile[]

  @@map("users")
}

model Profile {
  userId           String  @id @map("user_id")
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role             String  @default("aluno")
  booksRead        BigInt? @default(0) @map("books_read")
  permissions      Json?
  functions        String?
  progress         Json?
  favorites        Json?   @default("[]")
  name             String?
  icone            String?
  booksReadHistory Json?   @default("[]") @map("books_read_history")

  @@map("profiles")
}

model Author {
  id        BigInt    @id @default(autoincrement())
  name      String
  bio       String?
  photoUrl  String?   @map("photo_url")
  createdAt DateTime? @default(now()) @map("created_at")
  books     Book[]

  @@map("authors")
}

model Category {
  id        BigInt    @id @default(autoincrement())
  name      String
  imageUrl  String?   @map("image_url")
  createdAt DateTime? @default(now()) @map("created_at")
  books     Book[]

  @@map("categories")
}

model Book {
  id            BigInt    @id @default(autoincrement())
  title         String
  author        String?
  description   String?
  coverImage    String?   @map("cover_image")
  pages         Json?
  createdAt     DateTime? @default(now()) @map("created_at")
  authorId      BigInt?   @map("author_id")
  categoryId    BigInt?   @map("category_id")
  linkSlidebook String?   @map("link_slidebook")

  authorRel   Author?   @relation(fields: [authorId], references: [id])
  categoryRel Category? @relation(fields: [categoryId], references: [id])

  @@map("books")
}

model MediaFile {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  filePath   String   @map("file_path")
  fileName   String   @map("file_name")
  fileType   String   @map("file_type")
  fileSize   BigInt   @map("file_size")
  bucketName String   @map("bucket_name")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([filePath])
  @@index([userId])
  @@map("media_files")
}
