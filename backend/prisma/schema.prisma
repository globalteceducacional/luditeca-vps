generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  editor
  professor
  aluno
}

/// Estado editorial da obra (trilha: rascunho → revisão → publicado → arquivo).
enum BookWorkflowStatus {
  draft
  review
  published
  archived
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  role         UserRole @default(editor)
  createdAt    DateTime @default(now()) @map("created_at")

  profile             Profile?
  mediaFiles          MediaFile[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([tokenHash])
  @@index([userId])
  @@map("password_reset_tokens")
}

model AdminAuditLog {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now()) @map("created_at")
  actorUserId String?  @map("actor_user_id")
  actionCode  String   @map("action_code")
  module      String
  targetType  String?  @map("target_type")
  targetId    String?  @map("target_id")
  bookId      BigInt?  @map("book_id")
  pageRef     String?  @map("page_ref")
  metadata    Json?
  ip          String?
  userAgent   String?  @map("user_agent")

  @@index([createdAt])
  @@index([actorUserId])
  @@index([bookId])
  @@index([actionCode])
  @@map("admin_audit_logs")
}

model Profile {
  userId         String   @id @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           UserRole @default(aluno)
  booksRead      BigInt?  @default(0) @map("books_read")
  permissions    Json?
  functions      String?
  progress       Json?
  favorites      Json?    @default("[]")
  name           String?
  icone          String?
  booksReadHistory Json?  @default("[]") @map("books_read_history")

  @@map("profiles")
}

model Author {
  id        BigInt    @id @default(autoincrement())
  name      String
  bio       String?
  photoUrl  String?   @map("photo_url")
  createdAt DateTime? @default(now()) @map("created_at")
  books     Book[]

  @@map("authors")
}

model Category {
  id        BigInt    @id @default(autoincrement())
  name      String
  imageUrl  String?   @map("image_url")
  createdAt DateTime? @default(now()) @map("created_at")
  books     Book[]

  @@map("categories")
}

model Book {
  id              BigInt              @id @default(autoincrement())
  title           String
  author          String?
  description     String?
  coverImage      String?             @map("cover_image")
  pages           Json?
  pagesV2         Json?               @map("pages_v2")
  createdAt       DateTime?           @default(now()) @map("created_at")
  authorId        BigInt?             @map("author_id")
  categoryId      BigInt?             @map("category_id")
  linkSlidebook   String?             @map("link_slidebook")
  workflowStatus  BookWorkflowStatus  @default(draft) @map("workflow_status")
  /// Personagens (lista de strings) para catálogo e busca.
  catalogCharacters Json?             @map("catalog_characters")
  /// Nome da coleção editorial.
  catalogCollection String?           @map("catalog_collection")
  /// Palavras-chave (lista de strings).
  catalogKeywords   Json?             @map("catalog_keywords")
  /// Nível / faixa etária ou pedagógico (texto livre).
  catalogLevel      String?           @map("catalog_level")
  /// Índice denormalizado (minúsculas); atualizado em cada gravação/publicação.
  searchIndex       String            @default("") @map("search_index")

  authorRel   Author?   @relation(fields: [authorId], references: [id])
  categoryRel Category? @relation(fields: [categoryId], references: [id])
  mediaFiles   MediaFile[]

  @@map("books")
}

model MediaFile {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  bookId     BigInt?  @map("book_id")
  filePath   String   @map("file_path")
  fileName   String   @map("file_name")
  fileType   String   @map("file_type")
  fileSize   BigInt   @map("file_size")
  bucketName String   @map("bucket_name")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book? @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([filePath])
  @@index([userId])
  @@index([bookId])
  @@map("media_files")
}

/// Telemetria técnica (latência, erros HTTP, falhas de mídia no browser) — separada da auditoria de negócio (EVT:*).
model TechnicalLog {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now()) @map("created_at")
  level       String
  category    String
  message     String   @db.VarChar(500)
  metadata    Json?
  requestId   String?  @map("request_id") @db.VarChar(64)
  route       String?  @db.VarChar(512)
  method      String?  @db.VarChar(16)
  statusCode  Int?     @map("status_code")
  durationMs  Int?     @map("duration_ms")
  userId      String?  @map("user_id")
  ip          String?
  userAgent   String?  @map("user_agent") @db.VarChar(500)

  @@index([createdAt])
  @@index([category])
  @@index([level])
  @@map("technical_logs")
}
