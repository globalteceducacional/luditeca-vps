# Copie para luditeca-vps/.env (opcional; docker-compose usa valores por defeito para db/minio).
JWT_SECRET=altere-para-uma-string-longa-e-aleatoria

# API — luditeca-vps/luditeca-back (.env)
# DATABASE_URL=postgresql://luditeca:luditeca@localhost:5432/luditeca?schema=public
# Front — luditeca-vps/luditeca-front (.env.local)
# NEXT_PUBLIC_API_URL=http://localhost:4000
# NEXT_PUBLIC_MEDIA_BASE_URL=http://localhost:9000

# Com Nginx na porta 8080 (docker-compose)
# NEXT_PUBLIC_API_URL=http://localhost:8080/api
# NEXT_PUBLIC_MEDIA_BASE_URL=http://localhost:8080/media
