# Modelo geral: desenvolvimento no PC = Postgres + API locais e ficheiros em disco.
# Docker (Nginx + Postgres + API com STORAGE_DRIVER=local) para testes integrados e VPS.

# Copie os blocos necessarios para:
# - backend/.env
# - frontend/.env

## BACKEND (luditeca-vps/backend/.env) — local
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/luditeca
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio
PORT=3020
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# Armazenamento em pasta (padrao). Ficheiros em backend/storage/<bucket>/...
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=./storage
PUBLIC_MEDIA_BASE=http://localhost:3020/media

# Testes / VPS com S3 ou MinIO (STORAGE_DRIVER=s3)
# STORAGE_DRIVER=s3
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=minio
# S3_SECRET_KEY=minio12345
# S3_FORCE_PATH_STYLE=true
# PUBLIC_MEDIA_BASE=http://localhost:8080/media

# Para testes de cadastro diretamente no app Flutter
ENABLE_PUBLIC_REGISTER=true

## FRONTEND (luditeca-vps/frontend/.env) — local (mesma origem de midia que a API)
NEXT_PUBLIC_API_URL=http://localhost:3020
NEXT_PUBLIC_MEDIA_BASE_URL=http://localhost:3020/media

# Stack Docker + Nginx na porta 8080 (rebuild do front apos alterar)
# NEXT_PUBLIC_API_URL=http://localhost:8080/api
# NEXT_PUBLIC_MEDIA_BASE_URL=http://localhost:8080/media
