# Copie para .env na raiz de luditeca-vps (mesma pasta que docker-compose.yml).
# docker compose carrega este ficheiro automaticamente.
#
# Armazenamento: disco local na API (volume Docker luditeca_storage -> /app/storage).
# Nao e usado MinIO; /media e servido pela API via Nginx.

# --- PostgreSQL ---
POSTGRES_USER=luditeca
POSTGRES_PASSWORD=troque-esta-senha-forte
POSTGRES_DB=luditeca

# --- API ---
JWT_SECRET=gerar-string-aleatoria-com-pelo-menos-32-caracteres
# URL publica que o browser usa para /media (igual ao proximo bloco, sem barra final em /media)
PUBLIC_MEDIA_BASE=https://seu-dominio.com/media
# Origens permitidas pelo CORS (sem barra final), separadas por virgula
CORS_ORIGIN=https://seu-dominio.com

# Opcional: 1 = desativa o seed automatico no arranque da API (quando nao ha utilizadores)
# SKIP_AUTO_SEED=1

# --- Next.js (embute no build; obrigatorio rebuild: docker compose build --no-cache web) ---
NEXT_PUBLIC_API_URL=https://seu-dominio.com/api
NEXT_PUBLIC_MEDIA_BASE_URL=https://seu-dominio.com/media
