import { useState, useEffect } from 'react';
import Head from 'next/head';
import Link from 'next/link';
import { useRouter } from 'next/router';
import { getCurrentUser, getBook, updateBook } from '../../lib/supabase';
import Draggable from 'react-draggable';

export default function PagesEditor() {
  const [book, setBook] = useState(null);
  const [loading, setLoading] = useState(true);
  const [user, setUser] = useState(null);
  const [currentPageIndex, setCurrentPageIndex] = useState(0);
  const [newBalloon, setNewBalloon] = useState({ text: '', audioPath: '' });
  const [saving, setSaving] = useState(false);
  const router = useRouter();
  const { bookId } = router.query;

  useEffect(() => {
    async function checkAuth() {
      const { user, error } = await getCurrentUser();
      
      if (!user) {
        router.push('/login');
        return;
      }
      
      setUser(user);
    }
    
    checkAuth();
  }, [router]);

  useEffect(() => {
    if (bookId) {
      fetchBook();
    }
  }, [bookId]);

  async function fetchBook() {
    setLoading(true);
    try {
      const { data, error } = await getBook(bookId);
      
      if (error) {
        throw error;
      }
      
      if (data) {
        // Se o livro não tiver nenhuma página, criar uma página padrão
        if (!data.pages || data.pages.length === 0) {
          data.pages = [
            {
              backgroundImage: '',
              balloons: []
            }
          ];
        }
        
        setBook(data);
      } else {
        alert('Livro não encontrado');
        router.push('/books');
      }
    } catch (error) {
      console.error('Erro ao carregar livro:', error);
      alert('Erro ao carregar livro');
    } finally {
      setLoading(false);
    }
  }

  const handleAddPage = () => {
    if (!book) return;
    
    const newPages = [...book.pages, {
      backgroundImage: '',
      balloons: []
    }];
    
    setBook({
      ...book,
      pages: newPages
    });
    
    setCurrentPageIndex(newPages.length - 1);
  };

  const handleDeletePage = async () => {
    if (!book || book.pages.length <= 1) return;
    
    if (window.confirm('Tem certeza que deseja excluir esta página?')) {
      const newPages = [...book.pages];
      newPages.splice(currentPageIndex, 1);
      
      setBook({
        ...book,
        pages: newPages
      });
      
      if (currentPageIndex >= newPages.length) {
        setCurrentPageIndex(newPages.length - 1);
      }
    }
  };

  const handleAddBalloon = () => {
    if (!book || !newBalloon.text) return;
    
    const newPages = [...book.pages];
    newPages[currentPageIndex].balloons.push({
      ...newBalloon,
      top: 100,
      left: 100
    });
    
    setBook({
      ...book,
      pages: newPages
    });
    
    setNewBalloon({ text: '', audioPath: '' });
  };

  const handleBalloonPositionChange = (index, data) => {
    const newPages = [...book.pages];
    newPages[currentPageIndex].balloons[index].top = data.y;
    newPages[currentPageIndex].balloons[index].left = data.x;
    
    setBook({
      ...book,
      pages: newPages
    });
  };

  const handleDeleteBalloon = (index) => {
    const newPages = [...book.pages];
    newPages[currentPageIndex].balloons.splice(index, 1);
    
    setBook({
      ...book,
      pages: newPages
    });
  };

  const handleSave = async () => {
    if (!book) return;
    
    setSaving(true);
    try {
      const { data, error } = await updateBook(book.id, { pages: book.pages });
      
      if (error) {
        throw error;
      }
      
      alert('Livro salvo com sucesso!');
    } catch (error) {
      console.error('Erro ao salvar livro:', error);
      alert('Erro ao salvar alterações');
    } finally {
      setSaving(false);
    }
  };

  if (loading) {
    return (
      <div className="flex items-center justify-center min-h-screen">
        <div className="text-center">
          <h2 className="text-xl font-semibold mb-2">Carregando...</h2>
          <div className="w-10 h-10 border-4 border-blue-500 border-t-transparent rounded-full animate-spin mx-auto"></div>
        </div>
      </div>
    );
  }

  if (!user || !book) {
    return null;
  }

  const currentPage = book.pages[currentPageIndex];

  return (
    <div className="min-h-screen bg-gray-50">
      <Head>
        <title>Editor de Páginas | UniverseTeca CMS</title>
      </Head>

      <header className="bg-white shadow">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center">
          <div>
            <h1 className="text-xl font-bold text-gray-800">Editor de Páginas</h1>
            <p className="text-sm text-gray-600">Livro: {book.title}</p>
          </div>
          <div className="flex items-center space-x-4">
            <Link href="/books" className="text-sm text-gray-600 hover:text-gray-800">
              Voltar para Livros
            </Link>
          </div>
        </div>
      </header>

      <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 grid grid-cols-1 lg:grid-cols-3 gap-6">
        {/* Coluna da esquerda: navegação entre páginas */}
        <div className="bg-white p-4 rounded-lg shadow-md">
          <div className="flex justify-between items-center mb-4">
            <h2 className="text-lg font-medium">Páginas</h2>
            <button
              onClick={handleAddPage}
              className="bg-green-600 hover:bg-green-700 text-white px-3 py-1 rounded-md text-sm"
            >
              Nova Página
            </button>
          </div>
          
          <div className="space-y-2 max-h-96 overflow-y-auto">
            {book.pages.map((page, index) => (
              <div
                key={index}
                onClick={() => setCurrentPageIndex(index)}
                className={`p-2 border rounded-md cursor-pointer ${
                  index === currentPageIndex ? 'bg-blue-50 border-blue-500' : 'border-gray-200'
                }`}
              >
                <div className="flex justify-between items-center">
                  <span className="font-medium">Página {index + 1}</span>
                  <span className="text-xs text-gray-500">{page.balloons.length} balões</span>
                </div>
              </div>
            ))}
          </div>
          
          <div className="mt-6">
            <button
              onClick={handleSave}
              disabled={saving}
              className={`w-full py-2 ${
                saving ? 'bg-blue-400' : 'bg-blue-600 hover:bg-blue-700'
              } text-white rounded-md`}
            >
              {saving ? 'Salvando...' : 'Salvar Alterações'}
            </button>
          </div>
        </div>
        
        {/* Coluna do meio: editor visual */}
        <div className="bg-white p-4 rounded-lg shadow-md lg:col-span-2">
          <div className="flex justify-between items-center mb-4">
            <h2 className="text-lg font-medium">Página {currentPageIndex + 1}</h2>
            <button
              onClick={handleDeletePage}
              disabled={book.pages.length <= 1}
              className={`${
                book.pages.length <= 1
                  ? 'bg-gray-300 cursor-not-allowed'
                  : 'bg-red-600 hover:bg-red-700'
              } text-white px-3 py-1 rounded-md text-sm`}
            >
              Excluir Página
            </button>
          </div>
          
          {/* Canvas de edição */}
          <div className="relative border-2 border-dashed border-gray-300 bg-gray-100 rounded-md h-96 overflow-hidden">
            {currentPage.backgroundImage ? (
              <img
                src={currentPage.backgroundImage}
                alt="Fundo da página"
                className="absolute inset-0 w-full h-full object-cover"
              />
            ) : (
              <div className="absolute inset-0 w-full h-full flex items-center justify-center">
                <span className="text-gray-500">
                  Sem imagem de fundo. Configure o plano de fundo abaixo.
                </span>
              </div>
            )}
            
            {/* Balões posicionáveis */}
            {currentPage.balloons.map((balloon, index) => (
              <Draggable
                key={index}
                defaultPosition={{ x: balloon.left, y: balloon.top }}
                onStop={(e, data) => handleBalloonPositionChange(index, data)}
              >
                <div className="absolute bg-white p-3 rounded-lg shadow-md border border-gray-300 cursor-move w-64">
                  <div className="flex justify-between items-start mb-2">
                    <p className="text-sm font-medium">{balloon.text}</p>
                    <button
                      onClick={() => handleDeleteBalloon(index)}
                      className="text-red-600 hover:text-red-800 text-xs"
                    >
                      x
                    </button>
                  </div>
                  <div className="text-xs text-gray-500">
                    {balloon.audioPath || 'Sem áudio'}
                  </div>
                  <div className="text-xs text-gray-400 mt-1">
                    Posição: {Math.round(balloon.left)}, {Math.round(balloon.top)}
                  </div>
                </div>
              </Draggable>
            ))}
          </div>
          
          {/* Controles de edição */}
          <div className="mt-4 space-y-4">
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-1">
                Imagem de Fundo
              </label>
              <input
                type="text"
                value={currentPage.backgroundImage || ''}
                onChange={(e) => {
                  const newPages = [...book.pages];
                  newPages[currentPageIndex].backgroundImage = e.target.value;
                  setBook({
                    ...book,
                    pages: newPages
                  });
                }}
                placeholder="URL da imagem de fundo"
                className="w-full px-3 py-2 border border-gray-300 rounded-md"
              />
            </div>
            
            <div className="border-t pt-4">
              <h3 className="text-sm font-medium text-gray-700 mb-2">Adicionar Balão</h3>
              <div className="grid grid-cols-1 md:grid-cols-2 gap-2">
                <input
                  type="text"
                  value={newBalloon.text}
                  onChange={(e) => setNewBalloon({ ...newBalloon, text: e.target.value })}
                  placeholder="Texto do balão"
                  className="px-3 py-2 border border-gray-300 rounded-md"
                />
                <input
                  type="text"
                  value={newBalloon.audioPath}
                  onChange={(e) => setNewBalloon({ ...newBalloon, audioPath: e.target.value })}
                  placeholder="Caminho do áudio (opcional)"
                  className="px-3 py-2 border border-gray-300 rounded-md"
                />
              </div>
              <button
                onClick={handleAddBalloon}
                disabled={!newBalloon.text}
                className={`mt-2 px-3 py-2 ${
                  !newBalloon.text
                    ? 'bg-gray-300 cursor-not-allowed'
                    : 'bg-blue-600 hover:bg-blue-700'
                } text-white rounded-md w-full`}
              >
                Adicionar Balão
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
} 