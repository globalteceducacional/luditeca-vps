# Desenvolvimento local: Postgres na maquina, API com STORAGE_DRIVER=local (pasta storage/).
# Ajuste a porta se o seu backend/.env usar outra (ex.: PORT=3020).
NEXT_PUBLIC_API_URL=http://localhost:3020
NEXT_PUBLIC_MEDIA_BASE_URL=http://localhost:3020/media

# So com MinIO/S3 no host (ex.: npm run dev:with-minio no backend + MinIO na 9000)
# NEXT_PUBLIC_MEDIA_BASE_URL=http://localhost:9000

# Stack Docker + Nginx na porta 8080 (rebuild apos alterar)
# NEXT_PUBLIC_API_URL=http://localhost:8080/api
# NEXT_PUBLIC_MEDIA_BASE_URL=http://localhost:8080/media
